# Virtual environment (never committed — recreated from requirements.txt)
.venv/

# Data files (raw + processed). Dataset is redistributed via its source link, not the repo,
# to keep history light and avoid shipping a licensed copy of the data.
data/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Jupyter checkpoints
.ipynb_checkpoints/

# OS cruft
.DS_Store

# Trained artifacts are build outputs regenerated by `python -m src.train` /
# `python -m src.evaluate` (the pickled pipeline, plus the JSON metadata/decision files).
# Ignored so the repo stays reviewable and the binary never drifts from the code; the
# directory itself is kept via .gitkeep.
models/*
!models/.gitkeep
