# Virtual environment (never committed — recreated from requirements.txt)
.venv/

# Data files (raw + processed). Dataset is redistributed via its source link, not the repo,
# to keep history light and avoid shipping a licensed copy of the data.
data/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Jupyter checkpoints
.ipynb_checkpoints/

# OS cruft
.DS_Store

# Trained model artifact is a build output regenerated by `python -m src.train`.
# Ignored so the repo stays reviewable and the binary never drifts from the code.
models/*.joblib
